# === Servidor ===
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# === Banco de dados ===
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=freky
POSTGRES_USER=freky
POSTGRES_PASSWORD=changeme

DATABASE_URL=postgresql://freky:changeme@postgres:5432/freky

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Modelo ===
MODEL_PATH=/app/model/weights/freky.onnx
CONFIDENCE_THRESHOLD=0.60
HIGH_CONFIDENCE_THRESHOLD=0.85

# === Watcher (Xport) ===
# Pasta de rede onde o Xport da HI-SCAN deposita as imagens
SCAN_INPUT_DIR=/scans/incoming
SCAN_ARCHIVE_DIR=/scans/archive

# === Dashboard ===
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
