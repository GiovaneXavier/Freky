# === Ambiente ===
# Valores: dev | test | production
# Em dev: aceita senha em texto puro e segredo JWT inseguro
FREKY_ENV=production
DEBUG=false

# === Banco de dados (SQL Server) ===
# Senha da conta SA — mínimo 8 chars, maiúscula, minúscula, número e símbolo
MSSQL_SA_PASSWORD=YourStrong!Passw0rd

# Formato: mssql://sa:<senha>@<host>:1433/<db>?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes
DATABASE_URL=mssql://sa:YourStrong!Passw0rd@sqlserver:1433/freky?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Modelo ===
MODEL_PATH=/app/model/weights/freky.onnx
CONFIDENCE_THRESHOLD=0.60
HIGH_CONFIDENCE_THRESHOLD=0.85

# === Watcher (Xport) ===
# Pasta de rede onde o Xport da HI-SCAN deposita as imagens
SCAN_INPUT_DIR=/scans/incoming
SCAN_ARCHIVE_DIR=/scans/archive

# === Autenticação ===
# Gere uma chave segura: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_EXPIRE_MINUTES=480

# Origens permitidas pelo CORS (separadas por virgula)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://dashboard

# Usuários em JSON — para prod use hash bcrypt: passlib.hash.bcrypt.hash("senha")
# Roles: "admin" | "operator"
FREKY_USERS='[{"username":"admin","password":"admin","role":"admin"}]'

# === Dashboard ===
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
